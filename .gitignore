# ==========================================
# 1. ЗАВИСИМОСТИ (DEPENDENCIES)
# ==========================================
node_modules/
.pnp
.pnp.js

# ==========================================
# 2. БЕЗОПАСНОСТЬ И КЛЮЧИ (ENVIRONMENT)
# 🔥 КРИТИЧЕСКИ ВАЖНО: Никогда не коммить пароли от БД и JWT
# ==========================================
.env
.env.*
!.env.example

# ==========================================
# 3. ЛОГИ И ТЕМПОВЫЕ ФАЙЛЫ (LOGS & TMP)
# ==========================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
tmp/
temp/

# ==========================================
# 4. PRISMA И БАЗА ДАННЫХ
# (Игнорируем локальные SQLite файлы, если вдруг решишь использовать их для тестов)
# ==========================================
*.db
*.db-journal
*.sqlite
*.sqlite3

# ==========================================
# 5. ЛОКАЛЬНЫЕ ЗАГРУЗКИ (UPLOADS)
# (Мы используем Cloudinary, но если multer сохранит что-то локально — в Git это не нужно)
# ==========================================
uploads/
public/uploads/

# ==========================================
# 6. КЭШ ДЕВОПСА И ТЕСТОВ (CACHE & COVERAGE)
# ==========================================
coverage/
.nyc_output/
.npm/
.eslintcache

# ==========================================
# 7. СИСТЕМНЫЕ ФАЙЛЫ И РЕДАКТОРЫ (OS & EDITORS)
# ==========================================
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?